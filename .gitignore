# Dependencies
node_modules/

# Next.js build output
.next/
out/

# Environment / secrets
.env
.env.local
.env.production
.env.development

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*


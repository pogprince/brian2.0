{
  "name": "brain",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx scripts/seed.ts",
    "electron": "electron .",
    "app": "electron .",
    "dist": "next build && electron-builder",
    "dist:win": "next build && electron-builder --win",
    "dist:mac": "next build && electron-builder --mac",
    "dist:linux": "next build && electron-builder --linux"
  },
  "build": {
    "appId": "com.brain.cognitive-os",
    "productName": "Brain",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "app/**/*",
      "components/**/*",
      "lib/**/*",
      "brain/**/*",
      "data/**/*",
      "scripts/**/*",
      "public/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.js",
      "tailwind.config.ts",
      "tsconfig.json",
      "postcss.config.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.svg"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.svg"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.svg"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.378.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "wait-on": "^9.0.4"
  }
}
